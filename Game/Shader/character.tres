code = "shader_type canvas_item;
render_mode blend_mix;

instance uniform float Blink = 0.0;
instance uniform bool InvincibleEffect = false;



void fragment() {
// Input:2
	vec4 n_out2p0 = COLOR;
	float n_out2p4 = n_out2p0.a;


// ColorConstant:4
	vec4 n_out4p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// FloatParameter:5
	float n_out5p0 = Blink;


// Mix:3
	vec3 n_out3p0 = mix(vec3(n_out2p0.xyz), vec3(n_out4p0.xyz), n_out5p0);


// BooleanParameter:10
	bool n_out10p0 = InvincibleEffect;


// Input:6
	float n_out6p0 = TIME;


// FloatOp:9
	float n_in9p1 = 20.00000;
	float n_out9p0 = n_out6p0 * n_in9p1;


// FloatFunc:7
	float n_out7p0 = sin(n_out9p0);


	float n_out11p0;
// Switch:11
	float n_in11p2 = 1.00000;
	n_out11p0 = mix(n_in11p2, n_out7p0, float(n_out10p0));


// FloatOp:8
	float n_out8p0 = n_out2p4 * n_out11p0;


// Output:0
	COLOR.rgb = n_out3p0;
	COLOR.a = n_out8p0;


}
